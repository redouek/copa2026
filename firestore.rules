rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Álbuns: qualquer usuário logado pode ler (ranking e troca de repetidas)
    match /albums/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null &&
        request.auth.token.email == 'douekweb@gmail.com';
    }

    // Perfis: qualquer usuário logado pode ler (para ver o ranking)
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        request.auth.token.email == 'douekweb@gmail.com';
      allow delete: if request.auth != null &&
        request.auth.token.email == 'douekweb@gmail.com';
    }

    // Listagem da coleção users: qualquer usuário logado
    match /users/{document=**} {
      allow list: if request.auth != null;
    }

    // Config (patrocínio etc): leitura pública, escrita apenas admin
    match /config/{docId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        request.auth.token.email == 'douekweb@gmail.com';
    }
  }
}
